{% extends 'base.html.twig' %}

{% block title %}Blog AdminRéseau{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1 class="text-center mb-5">Bienvenue sur mon blog !</h1>
    <div class="container">
        <h1 class="text-center mb-5">Notions Réseau</h1>

        <div class="row g-4">

            <div class="col-md-4">
            <a href="/notions/materiel" class="text-decoration-none">
                <div class="card h-100 shadow-sm text-center">
                <div class="card-body">
                    <h3>Matériel</h3>
                    <ul>Routeurs, switches, firewalls, câblage…</ul>
                        <li>Routeurs</li>
                        <li>Switches</li>
                        <li>Câblage</li>
                </div>
                </div>
            </a>
            </div>

            <div class="col-md-4">
            <a href="/notions/protocoles">
                <div class="card h-100 shadow-sm text-center">
                <div class="card-body">
                    <h3>Protocoles</h3>
                    <ul>
                        <li>TCP/IP</li>
                        <li>DNS</li>
                        <li>DHCP</li>
                        <li>HTTP…</li>
                    </ul>
                </div>
                </div>
            </a>
            </div>

            <div class="col-md-4">
            <a href="/notions/modeles">
                <div class="card h-100 shadow-sm text-center">
                <div class="card-body">
                    <h3>Modèles</h3>
                    <ul>OSI, TCP/IP et architecture réseau</ul>
                        <li>OSI</li>
                        <li>TCP/IP</li>
                        <li>Architecture réseau</li>
                    </ul>
                </div>
                </div>
            </a>
            </div>

        </div>
    </div>
</div>
{% endblock %}
